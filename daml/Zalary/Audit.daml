template FailedSalaryClaim
  with
    failedEmployerWallet : Party
    failedHrWallet : Party
    failedEmployeeWallet : Party
    failedCompanyId : Text
    failedPayrollId : Text
    failedPeriod : PayrollPeriod
    failedToken : TokenInstrument
    failedEmployeeExternalId : Text
    failedSalaryBreakdown : SalaryBreakdown
    failedAmount : Decimal
    failureReason : Text
    companyAdmin : Party
    failedAt : Time
  where
    signatory failedEmployerWallet
    observer failedHrWallet, failedEmployeeWallet, companyAdmin
    ensure
      failedAmount > 0.0
        && nonEmptyText failedCompanyId
        && nonEmptyText failedPayrollId
        && validTokenInstrument failedToken
        && nonEmptyText failedEmployeeExternalId
        && nonEmptyText failureReason
        && validPayrollPeriod failedPeriod
        && validSalaryBreakdown failedSalaryBreakdown
        && sameTokenInstrument failedSalaryBreakdown.token failedToken
        && failedSalaryBreakdown.netPay == failedAmount
