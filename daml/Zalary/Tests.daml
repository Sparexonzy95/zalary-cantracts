testRejectWrongEnrollment : Script ()
testRejectWrongEnrollment = script do
  (_platformAdmin, _companyAdmin, employer, hr, employee, usdcxAdmin, _platformConfigCid, companyCid) <- setupCompany "WRONG-ENROLL"
  wrongEmployee <- allocateParty "WrongEmployee-WRONG-ENROLL"
  let token = usdcxTestnet usdcxAdmin

  wrongEnrollmentCid <- createEnrollmentFromCompany companyCid hr employer wrongEmployee "EMP-WRONG"
  vaultCid <- createVaultFromCompany companyCid hr employer "PAYROLL-WRONG-ENROLLMENT" token 1

  submitMustFail hr do
    exerciseCmd vaultCid AddSalaryAllocation with
      allocationEmployeeWallet = employee
      employeeExternalId = "EMP-WRONG"
      salaryBreakdown = sampleSalary token
      enrollmentCid = wrongEnrollmentCid

  return ()

testRejectFundingBeforeFinalization : Script ()
testRejectFundingBeforeFinalization = script do
  (_platformAdmin, _companyAdmin, employer, hr, _employee, usdcxAdmin, _platformConfigCid, companyCid) <- setupCompany "FUND-BEFORE-FINAL"
  let token = usdcxTestnet usdcxAdmin
  vaultCid <- createVaultFromCompany companyCid hr employer "PAYROLL-NOT-FINALIZED" token 1

  submitMustFail employer do
    exerciseCmd vaultCid ConfirmFunding with
      fundingAmount = 1100.0
      fundingReference = "FUND-SHOULD-FAIL"
      fundingProof = None

  return ()

testRejectEarlyLeftoverWithdrawal : Script ()
testRejectEarlyLeftoverWithdrawal = script do
  (_platformAdmin, companyAdmin, employer, hr, employee, usdcxAdmin, _platformConfigCid, companyCid) <- setupCompany "LEFTOVER"
  let token = usdcxTestnet usdcxAdmin

  enrollmentCid <- createEnrollmentFromCompany companyCid hr employer employee "EMP-LEFTOVER"
  vaultCid <- createVaultFromCompany companyCid hr employer "PAYROLL-LEFTOVER" token 1

  (vaultWithAllocationCid, _allocationCid) <- submit hr do
    exerciseCmd vaultCid AddSalaryAllocation with
      allocationEmployeeWallet = employee
      employeeExternalId = "EMP-LEFTOVER"
      salaryBreakdown = sampleSalary token
      enrollmentCid

  finalizedVaultCid <- submit hr do
    exerciseCmd vaultWithAllocationCid FinalizeAllocations

  fundedVaultCid <- fundVault finalizedVaultCid employer companyAdmin token 1200.0 "FUND-LEFTOVER"

  activeVaultCid <- submit employer do
    exerciseCmd fundedVaultCid ActivatePayroll

  submitMustFail employer do
    exerciseCmd activeVaultCid WithdrawLeftovers with
      withdrawalReference = "EARLY-WITHDRAWAL-SHOULD-FAIL"

  return ()

testRejectDuplicateAllocation : Script ()
testRejectDuplicateAllocation = script do
  (_platformAdmin, _companyAdmin, employer, hr, employee, usdcxAdmin, _platformConfigCid, companyCid) <- setupCompany "DUPLICATE"
  let token = usdcxTestnet usdcxAdmin

  enrollmentCid <- createEnrollmentFromCompany companyCid hr employer employee "EMP-DUPLICATE"
  vaultCid <- createVaultFromCompany companyCid hr employer "PAYROLL-DUPLICATE" token 2

  (vaultWithAllocationCid, _allocationCid) <- submit hr do
    exerciseCmd vaultCid AddSalaryAllocation with
      allocationEmployeeWallet = employee
      employeeExternalId = "EMP-DUPLICATE"
      salaryBreakdown = sampleSalary token
      enrollmentCid

  submitMustFail hr do
    exerciseCmd vaultWithAllocationCid AddSalaryAllocation with
      allocationEmployeeWallet = employee
      employeeExternalId = "EMP-DUPLICATE-2"
      salaryBreakdown = secondSalary token
      enrollmentCid

  return ()

testRejectTokenNotAllowedForCompany : Script ()
testRejectTokenNotAllowedForCompany = script do
  (_platformAdmin, _companyAdmin, employer, hr, _employee, usdcxAdmin, _platformConfigCid, companyCid) <- setupCompany "TOKEN-BLOCK"

  submitMustFail hr do
    exerciseCmd companyCid CreatePayrollVault with
      hrWallet = hr
      employerWallet = employer
      payrollId = "PAYROLL-UNSUPPORTED-DAIX"
      payrollPeriod = samplePeriod
      payrollToken = unsupportedToken usdcxAdmin
      claimWindowStart = time (date 2026 Jun 1) 0 0 0
      claimWindowEnd = time (date 2026 Jun 8) 0 0 0
      expectedEmployeeCount = 1

  return ()

testPlatformCanAssignSecondToken : Script ()
testPlatformCanAssignSecondToken = script do
  (platformAdmin, companyAdmin, employer, hr, _employee, usdcxAdmin, platformConfigCid, companyCid) <- setupCompany "TOKEN-ALLOW"
  let token = usdcxTestnet usdcxAdmin
  let secondToken = secondaryToken usdcxAdmin

  updatedCompanyCid <- submitMulti [platformAdmin, companyAdmin] [] do
    exerciseCmd platformConfigCid UpdateCompanyAllowedTokens with
      companyCid
      companyAdmin
      newAllowedTokens = [token, secondToken]

  _vaultCid <- createVaultFromCompany updatedCompanyCid hr employer "PAYROLL-SECOND-TOKEN-ALLOWED" secondToken 1
  return ()

testRejectPayrollTokenMismatch : Script ()
testRejectPayrollTokenMismatch = script do
  (_platformAdmin, _companyAdmin, employer, hr, employee, usdcxAdmin, _platformConfigCid, companyCid) <- setupCompany "PAYROLL-TOKEN-MISMATCH"
  let token = usdcxTestnet usdcxAdmin
  let wrongToken = unsupportedToken usdcxAdmin

  enrollmentCid <- createEnrollmentFromCompany companyCid hr employer employee "EMP-PAYROLL-TOKEN-MISMATCH"
  vaultCid <- createVaultFromCompany companyCid hr employer "PAYROLL-TOKEN-MISMATCH" token 1

  submitMustFail hr do
    exerciseCmd vaultCid AddSalaryAllocation with
      allocationEmployeeWallet = employee
      employeeExternalId = "EMP-PAYROLL-TOKEN-MISMATCH"
      salaryBreakdown = sampleSalary wrongToken
      enrollmentCid

  return ()

testRejectClaimTicketAfterWindowEnd : Script ()
testRejectClaimTicketAfterWindowEnd = script do
  (_platformAdmin, companyAdmin, employer, hr, employee, usdcxAdmin, _platformConfigCid, companyCid) <- setupCompany "LATE-TICKET"
  let token = usdcxTestnet usdcxAdmin

  enrollmentCid <- createEnrollmentFromCompany companyCid hr employer employee "EMP-LATE-TICKET"
  now <- getTime

  vaultCid <- submit hr do
    exerciseCmd companyCid CreatePayrollVault with
      hrWallet = hr
      employerWallet = employer
      payrollId = "PAYROLL-LATE-TICKET"
      payrollPeriod = samplePeriod
      payrollToken = token
      claimWindowStart = now
      claimWindowEnd = addRelTime now (days 1)
      expectedEmployeeCount = 1

  (vaultWithAllocationCid, allocationCid) <- submit hr do
    exerciseCmd vaultCid AddSalaryAllocation with
      allocationEmployeeWallet = employee
      employeeExternalId = "EMP-LATE-TICKET"
      salaryBreakdown = sampleSalary token
      enrollmentCid

  finalizedVaultCid <- submit hr do
    exerciseCmd vaultWithAllocationCid FinalizeAllocations

  fundedVaultCid <- fundVault finalizedVaultCid employer companyAdmin token 1100.0 "FUND-LATE-TICKET"

  activeVaultCid <- submit employer do
    exerciseCmd fundedVaultCid ActivatePayroll

  _ <- passTime (days 2)

  submitMustFail hr do
    exerciseCmd allocationCid IssueClaimTicket with
      payrollVaultCid = activeVaultCid

  return ()

testDirectSettlementHelperRequiresValidAllocation : Script ()
testDirectSettlementHelperRequiresValidAllocation = script do
  (_platformAdmin, companyAdmin, employer, hr, employee, usdcxAdmin, _platformConfigCid, companyCid) <- setupCompany "DIRECT-SETTLEMENT"
  let token = usdcxTestnet usdcxAdmin

  enrollmentCid <- createEnrollmentFromCompany companyCid hr employer employee "EMP-DIRECT-SETTLEMENT"
  vaultCid <- createVaultFromCompany companyCid hr employer "PAYROLL-DIRECT-SETTLEMENT" token 1

  (vaultWithAllocationCid, allocationCid) <- submit hr do
    exerciseCmd vaultCid AddSalaryAllocation with
      allocationEmployeeWallet = employee
      employeeExternalId = "EMP-DIRECT-SETTLEMENT"
      salaryBreakdown = sampleSalary token
      enrollmentCid

  finalizedVaultCid <- submit hr do
    exerciseCmd vaultWithAllocationCid FinalizeAllocations

  fundedVaultCid <- fundVault finalizedVaultCid employer companyAdmin token 1100.0 "FUND-DIRECT-SETTLEMENT"

  activeVaultCid <- submit employer do
    exerciseCmd fundedVaultCid ActivatePayroll

  now <- getTime
  let settlementProof = transferProof token employer employee 1100.0 "SETTLE-DIRECT-SETTLEMENT" now

  settlementAuthCid <- submitMulti [employee, employer] [] do
    createCmd ClaimActionAuthorization with
      authHrWallet = hr
      authEmployerWallet = employer
      authEmployeeWallet = employee
      authCompanyId = "ZAL-DIRECT-SETTLEMENT"
      authPayrollId = "PAYROLL-DIRECT-SETTLEMENT"
      authPeriod = samplePeriod
      authToken = token
      authEmployeeExternalId = "EMP-DIRECT-SETTLEMENT"
      authAmount = 1100.0
      authSourceAllocationCid = allocationCid
      authAction = SettlementAction
      companyAdmin
      authorizedAt = now

  submitMustFail employer do
    exerciseCmd activeVaultCid RecordSettlement with
      settlementEmployeeWallet = employee
      settlementEmployeeExternalId = "EMP-DIRECT-SETTLEMENT"
      settlementAmount = 1100.0
      settlementProof
      settlementAuthCid

  return ()

testRejectSettlementProofWrongToken : Script ()
testRejectSettlementProofWrongToken = script do
  (_companyAdmin, employer, _hr, employee, usdcxAdmin, _token, activeVaultCid, _allocationCid, claimCid) <- setupClaimReadyPayroll "WRONG-PROOF-TOKEN"
  now <- getTime
  let settlementReference = "SETTLE-WRONG-PROOF-TOKEN"
  let settlementProof = transferProof (unsupportedToken usdcxAdmin) employer employee 1100.0 settlementReference now

  submitMustFail employer do
    exerciseCmd claimCid ConfirmSalarySettlement with
      payrollVaultCid = activeVaultCid
      settlementReference
      settlementProof

  return ()

