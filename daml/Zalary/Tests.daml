module Zalary.Tests where

import Daml.Script
import DA.Date
import DA.Time
import Zalary.Types
import Zalary.Platform
import Zalary.Company
import Zalary.Enrollment
import Zalary.Payroll
import Zalary.Sandbox.ZUSD

samplePeriod : PayrollPeriod
samplePeriod = PayrollPeriod with
  label = "June 2026"
  startsAt = date 2026 Jun 1
  endsAt = date 2026 Jun 30

usdcxTestnet : Party -> TokenInstrument
usdcxTestnet instrumentAdmin = TokenInstrument with
  symbol = "USDCx"
  instrumentId = "USDCx"
  instrumentAdmin
  utilityApiUrl = "https://api.utilities.digitalasset-staging.com"
  xReserveApiUrl = "https://xreserve-api-testnet.circle.com"

secondaryToken : Party -> TokenInstrument
secondaryToken instrumentAdmin = TokenInstrument with
  symbol = "ZUSDx"
  instrumentId = "ZUSDx"
  instrumentAdmin
  utilityApiUrl = "https://api.utilities.digitalasset-staging.com"
  xReserveApiUrl = "https://xreserve-api-testnet.circle.com"

unsupportedToken : Party -> TokenInstrument
unsupportedToken instrumentAdmin = TokenInstrument with
  symbol = "DAIx"
  instrumentId = "DAIx"
  instrumentAdmin
  utilityApiUrl = "https://api.utilities.digitalasset-staging.com"
  xReserveApiUrl = "https://xreserve-api-testnet.circle.com"

sampleSalary : TokenInstrument -> SalaryBreakdown
sampleSalary token = SalaryBreakdown with
  grossPay = 1000.0
  allowances = 200.0
  deductions = 100.0
  netPay = 1100.0
  token

secondSalary : TokenInstrument -> SalaryBreakdown
secondSalary token = SalaryBreakdown with
  grossPay = 900.0
  allowances = 100.0
  deductions = 50.0
  netPay = 950.0
  token

transferProof : TokenInstrument -> Party -> Party -> Decimal -> Text -> Time -> TokenTransferProof
transferProof token sender receiver amount transferReference executedAt = TokenTransferProof with
  token
  sender
  receiver
  amount
  transferReference
  transferInstructionCid = Some ("transfer-instruction-" <> transferReference)
  holdingCid = Some ("holding-" <> transferReference)
  executedAt

setupCompany
  : Text
  -> Script (Party, Party, Party, Party, Party, Party, ContractId ZalaryConfig, ContractId Company)
setupCompany suffix = script do
  platformAdmin <- allocateParty ("PlatformAdmin-" <> suffix)
  companyAdmin <- allocateParty ("CompanyAdmin-" <> suffix)
  employer <- allocateParty ("EmployerWallet-" <> suffix)
  hr <- allocateParty ("HRWallet-" <> suffix)
  employee <- allocateParty ("EmployeeWallet-" <> suffix)
  usdcxAdmin <- allocateParty ("USDCxAdmin-" <> suffix)

  now <- getTime
  let token = usdcxTestnet usdcxAdmin

  platformConfigCid <- submit platformAdmin do
    createCmd ZalaryConfig with
      platformAdmin
      supportedTokens = [token, secondaryToken usdcxAdmin]
      defaultToken = token
      isActive = True
      createdAt = now

  companyCid <- submitMulti [platformAdmin, companyAdmin] [] do
    exerciseCmd platformConfigCid CreateCompany with
      companyAdmin
      companyName = "Zalary Demo Ltd"
      companyId = "ZAL-" <> suffix
      adminWallets = [companyAdmin]
      hrWallets = [hr]
      employerWallets = [employer]
      allowedTokens = [token]

  return (platformAdmin, companyAdmin, employer, hr, employee, usdcxAdmin, platformConfigCid, companyCid)

createEnrollmentFromCompany
  : ContractId Company
  -> Party
  -> Party
  -> Party
  -> Text
  -> Script (ContractId EmployeeEnrollment)
createEnrollmentFromCompany companyCid hr employer employee employeeExternalId = script do
  submit hr do
    exerciseCmd companyCid CreateEmployeeEnrollment with
      hrWallet = hr
      employerWallet = employer
      employeeWallet = employee
      employeeExternalId

createVaultFromCompany
  : ContractId Company
  -> Party
  -> Party
  -> Text
  -> TokenInstrument
  -> Int
  -> Script (ContractId PayrollVault)
createVaultFromCompany companyCid hr employer payrollId payrollToken expectedEmployeeCount = script do
  now <- getTime
  submit hr do
    exerciseCmd companyCid CreatePayrollVault with
      hrWallet = hr
      employerWallet = employer
      payrollId
      payrollPeriod = samplePeriod
      payrollToken
      claimWindowStart = now
      claimWindowEnd = addRelTime now (days 7)
      expectedEmployeeCount

fundVault
  : ContractId PayrollVault
  -> Party
  -> Party
  -> TokenInstrument
  -> Decimal
  -> Text
  -> Script (ContractId PayrollVault)
fundVault vaultCid employer companyAdmin token amount fundingReference = script do
  now <- getTime
  (fundedVaultCid, _fundingReceiptCid) <- submit employer do
    exerciseCmd vaultCid ConfirmFunding with
      fundingAmount = amount
      fundingReference
      fundingProof = Some (transferProof token employer companyAdmin amount fundingReference now)
  return fundedVaultCid

setupClaimReadyPayroll
  : Text
  -> Script (Party, Party, Party, Party, Party, TokenInstrument, ContractId PayrollVault, ContractId SalaryAllocation, ContractId SalaryClaim)
setupClaimReadyPayroll suffix = script do
  (_platformAdmin, companyAdmin, employer, hr, employee, usdcxAdmin, _platformConfigCid, companyCid) <- setupCompany suffix
  let token = usdcxTestnet usdcxAdmin

  enrollmentCid <- createEnrollmentFromCompany companyCid hr employer employee ("EMP-" <> suffix)
  vaultCid <- createVaultFromCompany companyCid hr employer ("PAYROLL-" <> suffix) token 1

  (vaultWithAllocationCid, allocationCid) <- submit hr do
    exerciseCmd vaultCid AddSalaryAllocation with
      allocationEmployeeWallet = employee
      employeeExternalId = "EMP-" <> suffix
      salaryBreakdown = sampleSalary token
      enrollmentCid

  finalizedVaultCid <- submit hr do
    exerciseCmd vaultWithAllocationCid FinalizeAllocations

  fundedVaultCid <- fundVault finalizedVaultCid employer companyAdmin token 1100.0 ("FUND-" <> suffix)

  activeVaultCid <- submit employer do
    exerciseCmd fundedVaultCid ActivatePayroll

  (_updatedAllocationCid, ticketCid) <- submit hr do
    exerciseCmd allocationCid IssueClaimTicket with
      payrollVaultCid = activeVaultCid

  claimCid <- submit employee do
    exerciseCmd ticketCid RequestSalaryClaim

  return (companyAdmin, employer, hr, employee, usdcxAdmin, token, activeVaultCid, allocationCid, claimCid)

payrollHappyPath : Script ()
payrollHappyPath = script do
  (_companyAdmin, employer, _hr, employee, _usdcxAdmin, token, activeVaultCid, _allocationCid, claimCid) <- setupClaimReadyPayroll "HAPPY"

  now <- getTime
  let settlementReference = "SETTLE-HAPPY-001"
  let settlementProof = transferProof token employer employee 1100.0 settlementReference now

  (_settledVaultCid, _settledAllocationCid, _settlementReceiptCid, _payslipCid, _settledRecordCid) <- submit employer do
    exerciseCmd claimCid ConfirmSalarySettlement with
      payrollVaultCid = activeVaultCid
      settlementReference
      settlementProof

  return ()

testNormalPayrollHappyPathStillWorks : Script ()
testNormalPayrollHappyPathStillWorks = payrollHappyPath

setupZUSDIssuer : Text -> Script (Party, Party, Party, ContractId ZUSDIssuer)
setupZUSDIssuer suffix = script do
  issuer <- allocateParty ("ZUSDIssuer-" <> suffix)
  employer <- allocateParty ("ZUSDEmployer-" <> suffix)
  employee <- allocateParty ("ZUSDEmployee-" <> suffix)
  now <- getTime

  issuerCid <- submit issuer do
    createCmd ZUSDIssuer with
      issuer
      symbol = "ZUSD"
      environment = "sandbox"
      observers = []
      createdAt = now

  return (issuer, employer, employee, issuerCid)

testZUSDMintCreatesHoldingAndGrant : Script ()
testZUSDMintCreatesHoldingAndGrant = script do
  (issuer, employer, _employee, issuerCid) <- setupZUSDIssuer "MINT"

  (_holdingCid, _grantCid) <- submit issuer do
    exerciseCmd issuerCid MintZUSD with
      recipient = employer
      amount = 5000.0
      requestId = "faucet-request-mint"
      reference = "faucet-reference-mint"
      environment = "sandbox"

  return ()

testZUSDMintRejectsZeroOrNegativeAmount : Script ()
testZUSDMintRejectsZeroOrNegativeAmount = script do
  (issuer, employer, _employee, issuerCid) <- setupZUSDIssuer "MINT-REJECT"

  submitMustFail issuer do
    exerciseCmd issuerCid MintZUSD with
      recipient = employer
      amount = 0.0
      requestId = "faucet-request-zero"
      reference = "faucet-reference-zero"
      environment = "sandbox"

  submitMustFail issuer do
    exerciseCmd issuerCid MintZUSD with
      recipient = employer
      amount = -1.0
      requestId = "faucet-request-negative"
      reference = "faucet-reference-negative"
      environment = "sandbox"

  return ()

testZUSDTransferExactAmount : Script ()
testZUSDTransferExactAmount = script do
  (issuer, employer, employee, issuerCid) <- setupZUSDIssuer "TRANSFER-EXACT"

  (holdingCid, _grantCid) <- submit issuer do
    exerciseCmd issuerCid MintZUSD with
      recipient = employer
      amount = 100.0
      requestId = "faucet-request-transfer-exact"
      reference = "faucet-reference-transfer-exact"
      environment = "sandbox"

  (_receiverCid, changeCid) <- submit employer do
    exerciseCmd holdingCid TransferZUSD with
      receiver = employee
      amount = 100.0
      reference = "zalary-zusd-exact"

  case changeCid of
    None -> return ()
    Some _ -> abort "Exact ZUSD transfer should not create change"

testZUSDTransferPartialCreatesReceiverAndChange : Script ()
testZUSDTransferPartialCreatesReceiverAndChange = script do
  (issuer, employer, employee, issuerCid) <- setupZUSDIssuer "TRANSFER-PARTIAL"

  (holdingCid, _grantCid) <- submit issuer do
    exerciseCmd issuerCid MintZUSD with
      recipient = employer
      amount = 100.0
      requestId = "faucet-request-transfer-partial"
      reference = "faucet-reference-transfer-partial"
      environment = "sandbox"

  (_receiverCid, changeCid) <- submit employer do
    exerciseCmd holdingCid TransferZUSD with
      receiver = employee
      amount = 40.0
      reference = "zalary-zusd-partial"

  case changeCid of
    Some _ -> return ()
    None -> abort "Partial ZUSD transfer should create a change holding"

testZUSDTransferRejectsInsufficientBalance : Script ()
testZUSDTransferRejectsInsufficientBalance = script do
  (issuer, employer, employee, issuerCid) <- setupZUSDIssuer "TRANSFER-INSUFFICIENT"

  (holdingCid, _grantCid) <- submit issuer do
    exerciseCmd issuerCid MintZUSD with
      recipient = employer
      amount = 100.0
      requestId = "faucet-request-transfer-insufficient"
      reference = "faucet-reference-transfer-insufficient"
      environment = "sandbox"

  submitMustFail employer do
    exerciseCmd holdingCid TransferZUSD with
      receiver = employee
      amount = 101.0
      reference = "zalary-zusd-insufficient"

  return ()

testZUSDTransferRejectsZeroOrNegativeAmount : Script ()
testZUSDTransferRejectsZeroOrNegativeAmount = script do
  (issuer, employer, employee, issuerCid) <- setupZUSDIssuer "TRANSFER-REJECT"

  (holdingCid, _grantCid) <- submit issuer do
    exerciseCmd issuerCid MintZUSD with
      recipient = employer
      amount = 100.0
      requestId = "faucet-request-transfer-reject"
      reference = "faucet-reference-transfer-reject"
      environment = "sandbox"

  submitMustFail employer do
    exerciseCmd holdingCid TransferZUSD with
      receiver = employee
      amount = 0.0
      reference = "zalary-zusd-zero"

  submitMustFail employer do
    exerciseCmd holdingCid TransferZUSD with
      receiver = employee
      amount = -1.0
      reference = "zalary-zusd-negative"

  return ()

testZUSDNonOwnerCannotTransfer : Script ()
testZUSDNonOwnerCannotTransfer = script do
  (issuer, employer, employee, issuerCid) <- setupZUSDIssuer "NONOWNER"
  outsider <- allocateParty "ZUSDOutsider-NONOWNER"

  (holdingCid, _grantCid) <- submit issuer do
    exerciseCmd issuerCid MintZUSD with
      recipient = employer
      amount = 100.0
      requestId = "faucet-request-nonowner"
      reference = "faucet-reference-nonowner"
      environment = "sandbox"

  submitMustFail outsider do
    exerciseCmd holdingCid TransferZUSD with
      receiver = employee
      amount = 1.0
      reference = "zalary-zusd-nonowner"

  return ()

testPlatformConfigDeactivation : Script ()
testPlatformConfigDeactivation = script do
  (platformAdmin, companyAdmin, _employer, _hr, _employee, usdcxAdmin, platformConfigCid, companyCid) <- setupCompany "CONFIG-DEACTIVATE"
  let token = usdcxTestnet usdcxAdmin

  inactiveConfigCid <- submit platformAdmin do
    exerciseCmd platformConfigCid DeactivatePlatformConfig

  submitMultiMustFail [platformAdmin, companyAdmin] [] do
    exerciseCmd inactiveConfigCid UpdateCompanyAllowedTokens with
      companyCid
      companyAdmin
      newAllowedTokens = [token, secondaryToken usdcxAdmin]

  return ()

testRejectUnsupportedTokenThroughPlatformConfig : Script ()
testRejectUnsupportedTokenThroughPlatformConfig = script do
  platformAdmin <- allocateParty "PlatformAdmin-UNSUPPORTED-CONFIG"
  companyAdmin <- allocateParty "CompanyAdmin-UNSUPPORTED-CONFIG"
  employer <- allocateParty "EmployerWallet-UNSUPPORTED-CONFIG"
  hr <- allocateParty "HRWallet-UNSUPPORTED-CONFIG"
  usdcxAdmin <- allocateParty "USDCxAdmin-UNSUPPORTED-CONFIG"

  now <- getTime
  let token = usdcxTestnet usdcxAdmin

  platformConfigCid <- submit platformAdmin do
    createCmd ZalaryConfig with
      platformAdmin
      supportedTokens = [token]
      defaultToken = token
      isActive = True
      createdAt = now

  submitMultiMustFail [platformAdmin, companyAdmin] [] do
    exerciseCmd platformConfigCid CreateCompany with
      companyAdmin
      companyName = "Unsupported Token Ltd"
      companyId = "ZAL-UNSUPPORTED-CONFIG"
      adminWallets = [companyAdmin]
      hrWallets = [hr]
      employerWallets = [employer]
      allowedTokens = [token, unsupportedToken usdcxAdmin]

  return ()

testCompanyFactoryIsNonconsuming : Script ()
testCompanyFactoryIsNonconsuming = script do
  (_platformAdmin, _companyAdmin, employer, hr, employeeA, usdcxAdmin, _platformConfigCid, companyCid) <- setupCompany "FACTORY"
  employeeB <- allocateParty "EmployeeWallet-FACTORY-B"
  let token = usdcxTestnet usdcxAdmin

  _enrollmentA <- createEnrollmentFromCompany companyCid hr employer employeeA "EMP-FACTORY-A"
  _enrollmentB <- createEnrollmentFromCompany companyCid hr employer employeeB "EMP-FACTORY-B"

  _vaultCid <- createVaultFromCompany companyCid hr employer "PAYROLL-FACTORY-2026-06" token 2
  return ()

testRejectUnapprovedHRFactoryUse : Script ()
testRejectUnapprovedHRFactoryUse = script do
  (_platformAdmin, _companyAdmin, employer, _hr, employee, _usdcxAdmin, _platformConfigCid, companyCid) <- setupCompany "BADHR"
  fakeHr <- allocateParty "FakeHR-BADHR"

  submitMustFail fakeHr do
    exerciseCmd companyCid CreateEmployeeEnrollment with
      hrWallet = fakeHr
      employerWallet = employer
