# Zalary backend environment names.
# Keep real values in your deployment environment or an untracked .env file.

ZALARY_LEDGER_API_URL=
ZALARY_LEDGER_API_AUTH_TOKEN=
ZALARY_LEDGER_API_TOKEN_URL=
ZALARY_LEDGER_API_CLIENT_ID=
ZALARY_LEDGER_API_CLIENT_SECRET=
ZALARY_LEDGER_API_AUDIENCE=
ZALARY_LEDGER_API_TOKEN_SCOPE=daml_ledger_api
ZALARY_LEDGER_API_TLS_CA_FILE=
ZALARY_LEDGER_API_TIMEOUT_SECONDS=30

ZALARY_DAML_PACKAGE_NAME=zalary-usdcx-contracts
ZALARY_DAML_PACKAGE_ID=5ae1c32a3351f951e52a4a41205aa18818b55d9bb9f129327ffc9311d4460094
ZALARY_LEDGER_PARTY=5nsandbox-devnet-2::1220a14ca128063b8dc9d1ebb0bd22633be9f2168500f4dbc1ecaeb1855b14e5acf8
ZALARY_PLATFORM_ADMIN_PARTY=
ZALARY_PLATFORM_CONFIG_CONTRACT_ID=

ZALARY_DEFAULT_ACT_AS=
ZALARY_DEFAULT_READ_AS=
ZALARY_COMMAND_ID_PREFIX=zalary-backend
ZALARY_SYNC_START_OFFSET=
ZALARY_SYNC_PAGE_SIZE=100
ZALARY_ALLOW_SINGLE_PARTY_DEMO=false
ZALARY_ENABLE_DEMO_SETTLEMENT_PROOF=false
ZALARY_ALLOW_UNBOUND_DEMO_AUTH=false

ZALARY_TOKEN_TRANSFER_PROVIDER=usdcx
# Supported modes: token_standard or p2plending_custom. p2plending_custom is fail-closed
# until an active P2PLending USDCxRegistry contract and schema-safe command plan are visible.
ZALARY_USDCX_TRANSFER_PROVIDER=token_standard
ZALARY_USDCX_UTILITY_API_URL=https://api.utilities.digitalasset-staging.com
ZALARY_USDCX_XRESERVE_API_URL=https://xreserve-api-testnet.circle.com
ZALARY_USDCX_ALLOW_EXTERNAL_PROOF=false
ZALARY_USDCX_TRANSFER_TIMEOUT_SECONDS=60
ZALARY_USDCX_HOLDING_INTERFACE_ID=#splice-api-token-holding-v1:Splice.Api.Token.HoldingV1:Holding
ZALARY_USDCX_TRANSFER_FACTORY_INTERFACE_ID=#splice-api-token-transfer-instruction-v1:Splice.Api.Token.TransferInstructionV1:TransferFactory
ZALARY_USDCX_TRANSFER_INSTRUCTION_INTERFACE_ID=#splice-api-token-transfer-instruction-v1:Splice.Api.Token.TransferInstructionV1:TransferInstruction
# DevNet/TestNet staging TransferFactory registry endpoint. Use deployment-specific value outside staging.
ZALARY_USDCX_TRANSFER_FACTORY_ENDPOINT=https://api.utilities.digitalasset-staging.com/registry/transfer-instruction/v1/transfer-factory
ZALARY_USDCX_ALLOW_CANONICAL_TRANSFER_ARGUMENT=true
ZALARY_USDCX_TRANSFER_ARGUMENT_SHAPE=transfer_extra_args
ZALARY_USDCX_AUTO_ACCEPT_PENDING_TRANSFER=false

# Sandbox ZUSD test-token mode. Use only for local/devnet settlement testing.
# Set ZALARY_TOKEN_TRANSFER_PROVIDER=zalary_test_token to route payroll settlement through ZUSD.
ZALARY_TEST_TOKEN_ENABLED=false
ZALARY_TEST_TOKEN_ENVIRONMENT=sandbox
ZALARY_TEST_TOKEN_ISSUER_PARTY=
ZALARY_TEST_TOKEN_ISSUER_CONTRACT_ID=
ZALARY_TEST_TOKEN_MAX_GRANT_AMOUNT=5000.0000000000
ZALARY_TEST_TOKEN_DAILY_LIMIT=10000.0000000000
ZALARY_TEST_TOKEN_MONTHLY_LIMIT=50000.0000000000

DJANGO_SECRET_KEY=change-me-for-local-development
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
